{
  "buildCommand": "echo 'Static site, no build needed'",
  "outputDirectory": "site",
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*.js"
    }
  ],
  "cleanUrls": true
}
